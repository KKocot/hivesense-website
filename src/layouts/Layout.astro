---
import '../styles/global.css';
import AnimatedBackground from '../components/AnimatedBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'HiveSense — Semantic Search for Hive Blockchain',
  description = 'AI-powered vector search across millions of Hive posts. Discover content by meaning, not just keywords. Built with Ollama, pgvector, and HAF.',
} = Astro.props;

const canonicalUrl = 'https://gitlab.syncad.com/hive/hivesense';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-bg-base text-text-primary font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-accent-primary focus:px-4 focus:py-2 focus:text-bg-base focus:font-semibold"
    >
      Skip to content
    </a>
    <AnimatedBackground />
    <div class="relative z-[1]">
      <slot />
    </div>
  </body>
</html>
