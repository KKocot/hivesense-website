---
const steps = [
  {
    number: '01',
    title: 'Ingest & Chunk',
    description: 'HAF scheduler collects posts from Hive blocks. Text is cleaned, stripped of markdown/links, and split into 512-token chunks with overlap.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  },
  {
    number: '02',
    title: 'Embed',
    description: 'Each chunk is sent to Ollama for ML embedding generation. 768-dimensional vectors capture semantic meaning of the content.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>`,
  },
  {
    number: '03',
    title: 'Search',
    description: 'Vectors stored in PostgreSQL with pgvector. HNSW index enables sub-100ms cosine similarity search across millions of posts.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
  },
];
---

<section id="how-it-works" class="how-section" aria-labelledby="how-title">
  <div class="how-inner">
    <div class="section-header animate-fade-up">
      <span class="overline">How It Works</span>
      <h2 id="how-title" class="section-title">From Blockchain to Meaning</h2>
    </div>

    <div class="steps-grid">
      {steps.map((step, i) => (
        <div class="step-wrap">
          <div class="step-card animate-fade-up" style={`transition-delay: ${i * 80}ms;`}>
            <span class="step-number" aria-hidden="true">{step.number}</span>
            <div class="step-icon" aria-hidden="true" set:html={step.icon} />
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-section {
    padding: 4rem 1rem;
    background: var(--color-surface-1);
  }

  @media (min-width: 768px) {
    .how-section { padding: 6rem 1.5rem; }
  }

  .how-inner {
    max-width: 75rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 37.5rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .section-header { margin-bottom: 4rem; }
  }

  .overline {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-size: clamp(2rem, 3vw + 0.5rem, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .step-wrap {
    position: relative;
  }

  .step-card {
    position: relative;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    overflow: hidden;
  }

  .step-number {
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent-primary);
    opacity: 0.1;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1.25rem;
    color: var(--color-accent-primary);
    background: var(--color-accent-primary-dim);
    border-radius: var(--radius-md);
  }

  .step-title {
    font-size: clamp(1.25rem, 1vw + 0.75rem, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 1024px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 50%;
      right: -0.75rem;
      width: 1.5rem;
      height: 0;
      border-top: 2px dashed var(--color-border);
      z-index: 1;
    }
  }
</style>
