---
const technologies = [
  {
    name: 'PostgreSQL',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v6c0 1.657 3.582 3 8 3s8-1.343 8-3V6"/><path d="M4 12v6c0 1.657 3.582 3 8 3s8-1.343 8-3v-6"/></svg>`,
  },
  {
    name: 'pgvector',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><line x1="6" y1="8" x2="12" y2="16"/><line x1="18" y1="8" x2="12" y2="16"/><line x1="8" y1="6" x2="16" y2="6"/></svg>`,
  },
  {
    name: 'Ollama',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a7 7 0 0 0-7 7v2a3 3 0 0 0 0 6v1a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4v-1a3 3 0 0 0 0-6V9a7 7 0 0 0-7-7z"/><circle cx="9" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="12" r="1" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    name: 'HAF',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    name: 'PostgREST',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h16"/><circle cx="8" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="10" cy="18" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    name: 'Docker',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="10" width="20" height="10" rx="2"/><rect x="5" y="6" width="4" height="4"/><rect x="10" y="6" width="4" height="4"/><rect x="10" y="2" width="4" height="4"/><path d="M15 8h4a2 2 0 0 1 2 2"/></svg>`,
  },
];
---

<section class="trust-bar animate-fade-up" aria-label="Technologies used">
  <div class="trust-inner">
    <div class="trust-logos">
      {technologies.map((tech) => (
        <div class="trust-item" title={tech.name}>
          <span class="trust-icon" set:html={tech.icon} aria-hidden="true" />
          <span class="trust-name">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-bar {
    padding: 3rem 1rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-inner {
    max-width: 75rem;
    margin: 0 auto;
    text-align: center;
  }

  .trust-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 639px) {
    .trust-logos { gap: 1.5rem; }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.5;
    transition: opacity var(--transition-fast);
  }

  .trust-item:hover {
    opacity: 1;
  }

  .trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .trust-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }
</style>
