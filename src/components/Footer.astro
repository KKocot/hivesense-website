---
const currentYear = new Date().getFullYear();
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href="https://gitlab.syncad.com/hive/hivesense"
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="HiveSense v1.0.0 — GitLab repository"
        >[hivesense v1.0.0]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__segment"
      >&copy; {currentYear} HiveSense</span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://gitlab.syncad.com/hive/hivesense/-/blob/main/LICENSE"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://gitlab.syncad.com/hive/hivesense"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="HiveSense on GitLab — opens in new tab"
      >GitLab</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://hive.io"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive blockchain ecosystem — opens in new tab"
      >built for <span class="tmux-status__hive">hive</span></a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://tools.openhive.network"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive Tools — opens in new tab"
      >Hive Tools</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__dot"
      aria-label="Status: online">●</span
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface, #12131a);
    border-top: 1px solid var(--tui-panel-border-color, rgba(255, 255, 255, 0.08));
    font-family: var(--font-mono, monospace);
    font-size: var(--text-xs, 0.75rem);
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    padding: var(--space-2, 0.5rem) var(--space-4, 1rem);
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-muted, rgba(255, 255, 255, 0.4));
    padding-inline: 0.625em;
    opacity: 0.5;
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-fast, 150ms) var(--ease-out-quad, ease-out),
                text-shadow var(--duration-fast, 150ms) var(--ease-out-quad, ease-out);
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-primary-bright, #00d4aa);
    text-shadow: var(--glow-intensity, 0 0 8px) var(--glow-color, #00d4aa);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-accent-primary, #00d4aa);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .tmux-status__hive {
    color: var(--color-hive-text, #ff5070);
    font-weight: 600;
  }

  .tmux-status__dot {
    color: var(--color-accent-success, #00d4aa);
    font-size: 0.625rem;
    line-height: 1;
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      gap: 0.25rem 0.5rem;
      padding: var(--space-2, 0.5rem) var(--space-2, 0.5rem);
    }
  }
</style>
