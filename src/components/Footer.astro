---
import { LINKS } from "../config/links";
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href={LINKS.HIVESENSE}
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="HiveSense — opens in new tab"
        >[hivesense]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.MIT_LICENSE}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.HIVE}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive blockchain — opens in new tab"
      >Hive</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.HIVE_TOOLS}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive Tools — opens in new tab"
      >Hive Tools</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={LINKS.BLOCKCHAIN_WARES}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Blockchain Wares — opens in new tab"
      >Blockchain Wares</a
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--tui-panel-border-color);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: var(--space-2) var(--space-4);
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-muted);
    padding-inline: var(--space-2);
    opacity: 0.5;
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out-quad);
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-primary-bright);
    text-shadow: var(--glow-intensity) var(--glow-color);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      padding: var(--space-2) var(--space-2);
      justify-content: center;
    }
  }
</style>
