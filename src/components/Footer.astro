---
const productLinks = [
  { label: 'Features', href: '#features' },
  { label: 'API', href: '#api' },
  { label: 'Documentation', href: 'https://gitlab.syncad.com/hive/hivesense/-/blob/develop/README.md', external: true },
  { label: 'GitLab', href: 'https://gitlab.syncad.com/hive/hivesense', external: true },
];

const ecosystemLinks = [
  { label: 'Hive.io', href: 'https://hive.io', external: true },
  { label: 'Hivemind', href: 'https://gitlab.syncad.com/hive/hivemind', external: true },
  { label: 'HAF', href: 'https://gitlab.syncad.com/hive/haf', external: true },
  { label: 'PeakD', href: 'https://peakd.com', external: true },
];

const resourceLinks = [
  { label: 'Installation Guide', href: 'https://gitlab.syncad.com/hive/hivesense/-/blob/develop/README.md', external: true },
  { label: 'API Reference', href: 'https://api.hive.blog/hivesense-swagger', external: true },
  { label: 'Contributing', href: 'https://gitlab.syncad.com/hive/hivesense/-/blob/develop/CONTRIBUTING.md', external: true },
  { label: 'License', href: 'https://gitlab.syncad.com/hive/hivesense/-/blob/develop/LICENSE', external: true },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="HiveSense home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M16 2L28 9V23L16 30L4 23V9L16 2Z" stroke="var(--color-accent-primary)" stroke-width="1.5" fill="none" />
            <circle cx="16" cy="12" r="2" fill="var(--color-accent-primary)" />
            <circle cx="10" cy="20" r="2" fill="var(--color-accent-primary)" />
            <circle cx="22" cy="20" r="2" fill="var(--color-accent-primary)" />
            <line x1="16" y1="12" x2="10" y2="20" stroke="var(--color-accent-primary)" stroke-width="1" opacity="0.6" />
            <line x1="16" y1="12" x2="22" y2="20" stroke="var(--color-accent-primary)" stroke-width="1" opacity="0.6" />
            <line x1="10" y1="20" x2="22" y2="20" stroke="var(--color-accent-primary)" stroke-width="1" opacity="0.6" />
          </svg>
          <span class="footer-logo-text">HiveSense</span>
        </a>
        <p class="footer-desc">Semantic search for the decentralized web. A HAF application for the Hive blockchain.</p>
      </div>

      <div class="footer-links-group">
        <h3 class="footer-heading">Product</h3>
        <ul class="footer-list">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
                {link.external && (
                  <svg class="footer-external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" /></svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-links-group">
        <h3 class="footer-heading">Hive Ecosystem</h3>
        <ul class="footer-list">
          {ecosystemLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
                <svg class="footer-external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" /></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-links-group">
        <h3 class="footer-heading">Resources</h3>
        <ul class="footer-list">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
                <svg class="footer-external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" /></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">2025 HiveSense. Open source under MIT License.</p>
      <a
        href="https://gitlab.syncad.com/hive/hivesense"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-gitlab"
        aria-label="HiveSense on GitLab (opens in new tab)"
      >
        <svg class="size-5" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 30.4L21.3 14.1H10.7L16 30.4Z"/><path d="M16 30.4L10.7 14.1H2.4L16 30.4Z" opacity="0.7"/><path d="M2.4 14.1L0.5 20.1C0.3 20.7 0.5 21.4 1 21.8L16 30.4L2.4 14.1Z" opacity="0.5"/><path d="M2.4 14.1H10.7L7.4 3.9C7.2 3.3 6.4 3.3 6.2 3.9L2.4 14.1Z"/><path d="M16 30.4L21.3 14.1H29.6L16 30.4Z" opacity="0.7"/><path d="M29.6 14.1L31.5 20.1C31.7 20.7 31.5 21.4 31 21.8L16 30.4L29.6 14.1Z" opacity="0.5"/><path d="M29.6 14.1H21.3L24.6 3.9C24.8 3.3 25.6 3.3 25.8 3.9L29.6 14.1Z"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 1rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .footer { padding: 3rem 1.5rem 2rem; }
  }

  .footer-inner {
    max-width: 75rem;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .footer-brand {
    max-width: 18rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .footer-logo-text {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .footer-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }

  .footer-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }

  .footer-external-icon {
    opacity: 0.5;
    flex-shrink: 0;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-gitlab {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-gitlab:hover {
    color: var(--color-text-primary);
  }
</style>
