---
const modules = [
  {
    name: 'semantic-search/',
    desc: 'Search by meaning, not keywords.',
    stat: '<100ms',
    last: false,
  },
  {
    name: 'similar-posts/',
    desc: 'HNSW nearest neighbors.',
    stat: '<100ms response',
    last: false,
  },
  {
    name: 'thematic-authors/',
    desc: 'Find contributors by topic expertise.',
    stat: null,
    last: false,
  },
  {
    name: 'smart-chunking/',
    desc: '512 tokens, 15% overlap, sentence-aware.',
    stat: null,
    last: false,
  },
  {
    name: 'realtime-sync/',
    desc: 'HAF-based blockchain scheduler.',
    stat: null,
    last: false,
  },
  {
    name: 'open-source/',
    desc: 'Self-host or use public API.',
    stat: null,
    last: true,
  },
];
---

<section id="features" class="features-section" aria-labelledby="features-title">
  <div class="features-container">
    <div class="section-header animate-fade-up">
      <h2 id="features-title" class="section-title">Modules</h2>
      <p class="section-subtitle">Six modules. One API surface.</p>
    </div>

    <div class="terminal-wrap animate-fade-up" style="transition-delay: 80ms;">
      <div class="code-block" role="img" aria-label="Tree view of HiveSense modules: semantic-search, similar-posts, thematic-authors, smart-chunking, realtime-sync, open-source">
        <div class="code-body">
          <div class="tree-command" aria-hidden="true">
            <span class="tree-prompt">$</span> tree hivesense/modules/
          </div>

          <div class="tree-output" role="list" aria-label="Module list">
            <div class="tree-root" aria-hidden="true">hivesense/modules/</div>

            {modules.map((mod, i) => (
              <div
                class="tree-line"
                role="listitem"
                data-tree-index={i}
              >
                <span class="tree-connector" aria-hidden="true">{mod.last ? '└── ' : '├── '}</span><span class="tree-module">{mod.name}</span>
                <span class="tree-spacer" aria-hidden="true">{' '.repeat(Math.max(1, 22 - mod.name.length))}</span>
                <span class="tree-desc">{mod.desc}</span>
                {mod.stat && (
                  <span class="tree-stat"> {mod.stat}</span>
                )}
              </div>
            ))}
          </div>

          <div class="tree-summary" aria-hidden="true">
            <br />6 directories, 0 files
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initTreeAnimation() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const terminalWrap = document.querySelector('.terminal-wrap');
    if (!terminalWrap) return;

    const lines = terminalWrap.querySelectorAll<HTMLElement>('.tree-line');
    const command = terminalWrap.querySelector<HTMLElement>('.tree-command');
    const root = terminalWrap.querySelector<HTMLElement>('.tree-root');
    const summary = terminalWrap.querySelector<HTMLElement>('.tree-summary');

    if (prefersReduced) {
      // Show everything immediately
      [command, root, summary].forEach(el => {
        if (el) el.style.opacity = '1';
      });
      lines.forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // Hide elements initially
    [command, root, summary].forEach(el => {
      if (el) el.style.opacity = '0';
    });
    lines.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(0.25rem)';
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Animate command prompt
            if (command) {
              command.style.transition = 'opacity 300ms ease-out';
              command.style.opacity = '1';
            }

            // Animate root path
            setTimeout(() => {
              if (root) {
                root.style.transition = 'opacity 300ms ease-out';
                root.style.opacity = '1';
              }
            }, 200);

            // Animate each tree line with stagger
            lines.forEach((line, i) => {
              setTimeout(() => {
                line.style.transition = 'opacity 300ms ease-out, transform 300ms ease-out';
                line.style.opacity = '1';
                line.style.transform = 'translateY(0)';
              }, 350 + i * 120);
            });

            // Animate summary
            setTimeout(() => {
              if (summary) {
                summary.style.transition = 'opacity 300ms ease-out';
                summary.style.opacity = '1';
              }
            }, 350 + lines.length * 120 + 100);

            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -40px 0px' },
    );

    observer.observe(terminalWrap);
  }

  // Run on load and on Astro page transitions
  initTreeAnimation();
  document.addEventListener('astro:after-swap', initTreeAnimation);
</script>

<style>
  .features-section {
    padding: 4rem 1rem;
  }

  @media (min-width: 768px) {
    .features-section { padding: 6rem 1.5rem; }
  }

  .features-container {
    max-width: 50rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .section-header { margin-bottom: 3rem; }
  }

  .section-title {
    font-size: clamp(2rem, 3vw + 0.5rem, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Code block */
  .terminal-wrap {
    width: 100%;
  }

  .code-block {
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .code-body {
    padding: 1.25rem 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.75;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  @media (min-width: 768px) {
    .code-body {
      padding: 1.5rem 1.5rem 1.75rem;
      font-size: 0.9375rem;
    }
  }

  /* Command prompt line */
  .tree-command {
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
    white-space: pre;
  }

  .tree-prompt {
    color: var(--color-accent-primary);
    font-weight: 600;
  }

  /* Root directory */
  .tree-root {
    color: var(--color-text-primary);
    font-weight: 600;
    white-space: pre;
  }

  /* Tree lines */
  .tree-line {
    white-space: pre;
    will-change: opacity, transform;
  }

  .tree-connector {
    color: var(--color-text-muted);
    opacity: 0.4;
    user-select: none;
  }

  .tree-module {
    color: var(--color-accent-primary);
    font-weight: 500;
  }

  .tree-spacer {
    user-select: none;
  }

  .tree-desc {
    color: var(--color-text-muted);
  }

  .tree-stat {
    color: var(--color-accent-secondary);
    font-weight: 500;
  }

  /* Summary */
  .tree-summary {
    color: var(--color-text-muted);
    opacity: 0.5;
    white-space: pre;
  }

  /* Small screens: tighter spacing */
  @media (max-width: 479px) {
    .code-body {
      padding: 1rem 0.75rem 1.25rem;
      font-size: 0.6875rem;
      line-height: 1.85;
    }
  }

  @media (min-width: 480px) and (max-width: 639px) {
    .code-body {
      font-size: 0.75rem;
    }
  }
</style>
