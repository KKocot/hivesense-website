---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m8 8 2 2"/><path d="m14 8-2 2"/><path d="m8 14 2-2"/></svg>`,
    title: 'Semantic Search',
    description: 'Search by meaning, not keywords. Find posts about "blockchain governance" even when those words aren\'t used.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="12" cy="18" r="3"/><line x1="8.5" y1="7.5" x2="10.5" y2="16"/><line x1="15.5" y1="7.5" x2="13.5" y2="16"/><line x1="9" y1="6" x2="15" y2="6"/></svg>`,
    title: 'Similar Posts',
    description: 'Discover related content for any post. HNSW-indexed vector similarity returns results in <100ms.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><circle cx="19" cy="6" r="2"/><circle cx="22" cy="13" r="2"/><line x1="19" y1="8" x2="22" y2="11" opacity="0.5"/></svg>`,
    title: 'Thematic Contributors',
    description: 'Find authors who write about specific topics across the entire blockchain.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="12" y2="16"/><path d="M14 2v4h6" opacity="0.5"/></svg>`,
    title: 'Smart Chunking',
    description: 'Posts split into 512-token chunks with 15% overlap. No meaning lost at boundaries.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6"/><path d="M2.5 12A10 10 0 0 1 18.4 4.6"/><path d="M21.5 12A10 10 0 0 1 5.6 19.4"/></svg>`,
    title: 'Real-time Sync',
    description: 'HAF-based scheduler continuously processes new blocks. Always up to date.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><path d="M12 2v20" opacity="0.3"/></svg>`,
    title: 'Open Source',
    description: 'Fully open source, deployed on Hive infrastructure. Run your own node or use the public API.',
  },
];
---

<section id="features" class="features-section" aria-labelledby="features-title">
  <div class="features-container">
    <div class="section-header animate-fade-up">
      <span class="overline">Features</span>
      <h2 id="features-title" class="section-title">What HiveSense Does</h2>
      <p class="section-subtitle">ML-powered semantic understanding of Hive blockchain content.</p>
    </div>

    <div class="features-grid animate-stagger">
      {features.map((feature, i) => (
        <div class="feature-card animate-fade-up" style={`transition-delay: ${i * 60}ms;`}>
          <div class="feature-icon-wrap" aria-hidden="true">
            <span set:html={feature.icon} />
          </div>
          <h3 class="feature-card-title">{feature.title}</h3>
          <p class="feature-card-desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 4rem 1rem;
  }

  @media (min-width: 768px) {
    .features-section { padding: 6rem 1.5rem; }
  }

  .features-container {
    max-width: 75rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 37.5rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .section-header { margin-bottom: 4rem; }
  }

  .overline {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-size: clamp(2rem, 3vw + 0.5rem, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }

  @media (min-width: 1024px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  }

  .feature-card {
    position: relative;
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: transform var(--transition-base),
                box-shadow var(--transition-base),
                border-color var(--transition-fast);
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-hover);
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent-primary-mid), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  .feature-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-accent-primary-dim);
    border-radius: var(--radius-md);
    color: var(--color-accent-primary);
  }

  .feature-card-title {
    font-size: clamp(1.25rem, 1vw + 0.75rem, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-top: 1.25rem;
  }

  .feature-card-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
</style>
